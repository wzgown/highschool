/* 全局样式 */
page {
  --color-primary: #409EFF;
  --color-success: #67C23A;
  --color-warning: #E6A23C;
  --color-danger: #F56C6C;
  --color-info: #909399;
  --color-text-primary: #303133;
  --color-text-regular: #606266;
  --color-text-secondary: #909399;
  --color-border: #DCDFE6;
  --color-bg: #F5F7FA;
  --color-bg-card: #FFFFFF;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg);
}

.container {
  padding: 24rpx;
}

/* 通用卡片 */
.card {
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.card-header-icon {
  font-size: 36rpx;
  color: var(--color-primary);
}

/* 通用按钮 */
.btn-primary {
  background-color: var(--color-primary);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background-color: #ffffff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.btn-disabled {
  opacity: 0.5;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.tag-primary {
  background-color: rgba(64, 158, 255, 0.1);
  color: var(--color-primary);
  border: 1rpx solid rgba(64, 158, 255, 0.2);
}

.tag-success {
  background-color: rgba(103, 194, 58, 0.1);
  color: var(--color-success);
  border: 1rpx solid rgba(103, 194, 58, 0.2);
}

.tag-warning {
  background-color: rgba(230, 162, 60, 0.1);
  color: var(--color-warning);
  border: 1rpx solid rgba(230, 162, 60, 0.2);
}

.tag-danger {
  background-color: rgba(245, 108, 108, 0.1);
  color: var(--color-danger);
  border: 1rpx solid rgba(245, 108, 108, 0.2);
}

.tag-info {
  background-color: rgba(144, 147, 153, 0.1);
  color: var(--color-info);
  border: 1rpx solid rgba(144, 147, 153, 0.2);
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.form-required {
  color: var(--color-danger);
  margin-right: 4rpx;
}

.form-tip {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: #ffffff;
  box-sizing: border-box;
}

.form-input-disabled {
  background-color: var(--color-bg);
  color: var(--color-text-secondary);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  background-color: #ffffff;
}

.form-picker-placeholder {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.form-picker-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-picker-arrow {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: var(--color-border);
  margin: 32rpx 0;
}

.divider-text {
  display: flex;
  align-items: center;
  margin: 32rpx 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.divider-text::before,
.divider-text::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background-color: var(--color-border);
}

.divider-text-text {
  padding: 0 24rpx;
}

/* 提示信息 */
.alert {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 16rpx;
}

.alert-warning {
  background-color: rgba(230, 162, 60, 0.1);
  color: var(--color-warning);
  border: 1rpx solid rgba(230, 162, 60, 0.2);
}

.alert-info {
  background-color: rgba(64, 158, 255, 0.1);
  color: var(--color-primary);
  border: 1rpx solid rgba(64, 158, 255, 0.2);
}

.alert-error {
  background-color: rgba(245, 108, 108, 0.1);
  color: var(--color-danger);
  border: 1rpx solid rgba(245, 108, 108, 0.2);
}

/* 操作栏 */
.actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 32rpx 0;
}

.actions button {
  flex: 1;
}
