{
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/recommendation/recommendation",
			"style": {
				"navigationBarTitleText": "智能志愿推荐"
			}
		},
		{
			"path": "pages/form/form",
			"style": {
				"navigationBarTitleText": "志愿填报",
				"mp-weixin": {
					"disableScroll": false
				}
			}
		},
		{
			"path": "pages/result/result",
			"style": {
				"navigationBarTitleText": "分析结果"
			}
		},
		{
			"path": "pages/history/history",
			"style": {
				"navigationBarTitleText": "历史记录"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "上海中考招生模拟",
		"navigationBarBackgroundColor": "#409EFF",
		"backgroundColor": "#F5F5F5",
		"mp-weixin": {
			"navigationStyle": "default",
			"navigationBarBackgroundColor": "#409EFF",
			"navigationBarTextStyle": "white"
		}
	},
	"tabBar": {
		"color": "#999999",
		"selectedColor": "#409EFF",
		"backgroundColor": "#ffffff",
		"borderStyle": "black",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "首页",
				"iconPath": "static/tabbar/home.svg",
				"selectedIconPath": "static/tabbar/home-active.svg"
			},
			{
				"pagePath": "pages/form/form",
				"text": "填报",
				"iconPath": "static/tabbar/form.svg",
				"selectedIconPath": "static/tabbar/form-active.svg"
			},
			{
				"pagePath": "pages/history/history",
				"text": "历史",
				"iconPath": "static/tabbar/history.svg",
				"selectedIconPath": "static/tabbar/history-active.svg"
			}
		]
	},
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	}
}
