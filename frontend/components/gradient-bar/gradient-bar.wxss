.gradient-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.gradient-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.gradient-label {
  width: 80rpx;
  font-size: 28rpx;
  color: var(--color-text-regular);
}

.gradient-bar {
  flex: 1;
  height: 24rpx;
  background-color: #EBEEF5;
  border-radius: 12rpx;
  overflow: hidden;
}

.gradient-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
}

.reach {
  background-color: #F56C6C;
}

.target {
  background-color: #E6A23C;
}

.safety {
  background-color: #67C23A;
}

.gradient-count {
  width: 80rpx;
  text-align: right;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
