.hero {
  position: relative;
  margin: -24rpx -24rpx 32rpx -24rpx;
  padding: 64rpx 48rpx;
  background: linear-gradient(135deg, #409EFF 0%, #337ECC 100%);
  color: #ffffff;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.85;
}

/* Connection Status */
.connection-status {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #f5f7fa;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-row.ok {
  color: #67C23A;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.testing {
  background-color: #E6A23C;
  animation: pulse 1s infinite;
}

.status-dot.ok {
  background-color: #67C23A;
}

.status-dot.fail {
  background-color: #F56C6C;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-block.fail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #F56C6C;
}

.status-url {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.status-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.btn-retry {
  margin-top: 8rpx;
  font-size: 24rpx;
  align-self: flex-start;
}

/* Actions */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
}

.action-card:active {
  opacity: 0.7;
}

.action-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.action-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.action-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.action-arrow {
  font-size: 36rpx;
  color: #c0c4cc;
  flex-shrink: 0;
}

.action-card-primary {
  border-left: 6rpx solid #409EFF;
}

.action-card-recommend {
  border-left: 6rpx solid #67C23A;
}

/* Batch Info */
.batch-info {
  margin-bottom: 32rpx;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.batch-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.batch-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Disclaimer */
.disclaimer {
  padding: 24rpx;
  text-align: center;
}

.disclaimer-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
