.hero {
  position: relative;
  margin: -24rpx -24rpx 32rpx -24rpx;
  padding: 64rpx 48rpx;
  background: linear-gradient(135deg, #409EFF 0%, #337ECC 100%);
  color: #ffffff;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.85;
}

/* Connection Status */
.connection-status {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #f5f7fa;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-row.ok {
  color: #67C23A;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.testing {
  background-color: #E6A23C;
  animation: pulse 1s infinite;
}

.status-dot.ok {
  background-color: #67C23A;
}

.status-dot.fail {
  background-color: #F56C6C;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-block.fail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #F56C6C;
}

.status-url {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.status-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.btn-retry {
  margin-top: 8rpx;
  font-size: 24rpx;
  align-self: flex-start;
}

/* Features */
.features {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40rpx 32rpx;
}

.feature-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* Actions */
.actions-main {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.btn-recommend {
  background-color: var(--color-success);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 0;
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  box-sizing: border-box;
  overflow: hidden;
}

.btn-recommend::after {
  border: none;
}

.btn-large {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}

/* Batch Info */
.batch-info {
  margin-bottom: 32rpx;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.batch-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.batch-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* Disclaimer */
.disclaimer {
  padding: 24rpx;
  text-align: center;
}

.disclaimer-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
