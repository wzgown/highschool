/* Loading */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* Header */
.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-count {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.refresh-icon {
  font-size: 28rpx;
  color: var(--color-primary);
}

.refresh-text {
  font-size: 24rpx;
  color: var(--color-primary);
}

/* History List */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* History Card */
.history-card {
  padding: 28rpx 32rpx;
}

/* Card Top */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--color-bg);
}

.delete-icon {
  font-size: 22rpx;
  color: var(--color-danger);
}

/* Card Summary */
.card-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.summary-volunteers {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.summary-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* Card Actions */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--color-border);
}

.detail-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.detail-text {
  font-size: 26rpx;
  color: var(--color-primary);
}

.detail-arrow {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 500;
}
