/* 步骤指示器 */
.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  margin-bottom: 16rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #ffffff;
  background-color: var(--color-info);
  transition: all 0.3s;
}

.step-item.active .step-circle {
  background-color: var(--color-primary);
}

.step-item.done .step-circle {
  background-color: var(--color-success);
}

.step-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.step-item.active .step-text {
  color: var(--color-primary);
  font-weight: 500;
}

.step-item.done .step-text {
  color: var(--color-success);
}

.step-line {
  flex: 1;
  height: 4rpx;
  background-color: var(--color-border);
  margin: 0 16rpx;
  margin-bottom: 32rpx;
}

.step-line.done {
  background-color: var(--color-success);
}

/* 步骤内容 */
.step-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 成绩卡片 */
.score-card {
  padding: 0;
  overflow: hidden;
}

.score-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--color-bg);
}

.score-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-max-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.score-body {
  padding: 24rpx 32rpx;
}

.score-empty {
  padding: 48rpx 32rpx;
  text-align: center;
}

.score-empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 分数转换提示 */
.conversion-hint {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.conversion-hint-primary {
  background-color: rgba(64, 158, 255, 0.1);
  color: var(--color-primary);
}

.conversion-hint-success {
  background-color: rgba(103, 194, 58, 0.1);
  color: var(--color-success);
}

/* 复选框行 */
.checkbox-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.checkbox-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

/* 加载 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}

/* 结果 Tab */
.result-tabs {
  display: flex;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid var(--color-border);
}

.result-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  background-color: #ffffff;
  color: var(--color-text-regular);
  transition: all 0.3s;
}

.result-tab.active {
  background-color: rgba(64, 158, 255, 0.08);
  color: var(--color-primary);
  font-weight: 500;
}

/* 分数转换网格 */
.conversion-grid {
  display: flex;
  gap: 24rpx;
}

.conversion-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 0;
}

.conversion-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.conversion-value {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

/* 推荐列表 */
.rec-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rec-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background-color: var(--color-bg);
}

.rec-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.rec-school {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.rec-details {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.rec-detail {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.rec-reason {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid var(--color-border);
}

/* 空状态 */
.empty-text {
  display: block;
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}
