/* Result Header */
.result-header {
  text-align: center;
  padding: 32rpx 0 24rpx;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.result-time {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* Error State */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  text-align: center;
}

.error-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: rgba(245, 108, 108, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.error-icon {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-danger);
}

.error-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.error-message {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.error-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.error-actions button {
  flex: 1;
}

/* Empty State */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  text-align: center;
}

.empty-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: rgba(230, 162, 60, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-warning);
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 40rpx;
}

/* Prediction Card */
.prediction-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.prediction-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 16rpx;
}

.prediction-value {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.prediction-unit {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-left: 8rpx;
}

.prediction-meta {
  margin-bottom: 16rpx;
}

.prediction-range {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background-color: var(--color-bg);
  border-radius: 8rpx;
}

.prediction-range-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.prediction-range-value {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

/* Probability List */
.probability-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Strategy Content */
.strategy-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-regular);
  margin-bottom: 16rpx;
}

.suggestion-section,
.warning-section {
  display: flex;
  flex-direction: column;
}

.suggestion-list,
.warning-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(103, 194, 58, 0.05);
  border-radius: 8rpx;
}

.suggestion-icon {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(103, 194, 58, 0.15);
  color: var(--color-success);
  font-size: 22rpx;
  font-weight: 700;
}

.suggestion-text {
  font-size: 26rpx;
  color: var(--color-text-regular);
  line-height: 1.6;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background-color: rgba(230, 162, 60, 0.05);
  border-radius: 8rpx;
}

.warning-icon {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(230, 162, 60, 0.15);
  color: var(--color-warning);
  font-size: 22rpx;
  font-weight: 700;
}

.warning-text {
  font-size: 26rpx;
  color: var(--color-text-regular);
  line-height: 1.6;
}

/* Competitor Analysis */
.competitor-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.competitor-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
}

.competitor-count-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.competitor-count-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
}

/* Probability Card */
.prob-card {
  padding: 24rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.prob-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.school-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  flex: 1;
}

.prob-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.prob-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.prob-bar-bg {
  flex: 1;
  height: 16rpx;
  background-color: #EBEEF5;
  border-radius: 8rpx;
  overflow: hidden;
}

.prob-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.prob-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  min-width: 72rpx;
  text-align: right;
}

.prob-no-data {
  color: var(--color-text-secondary, #999) !important;
  font-size: 26rpx;
}

.score-diff {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* Distribution Chart */
.distribution-chart {
  display: flex;
  flex-direction: column;
}

.distribution-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.distribution-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.distribution-label {
  flex-shrink: 0;
  width: 120rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: right;
}

.distribution-bar-bg {
  flex: 1;
  height: 24rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  overflow: hidden;
}

.distribution-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #66b1ff);
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.distribution-value {
  flex-shrink: 0;
  width: 80rpx;
  font-size: 24rpx;
  color: var(--color-text-regular);
}

/* Action Buttons */
.result-actions {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0 48rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 16rpx;
  padding: 0;
  margin: 0;
}
